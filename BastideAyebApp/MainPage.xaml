<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BastideAyebApp.MainPage"
             BackgroundColor="{StaticResource AppBackground}"> <ScrollView>
        <VerticalStackLayout Padding="30,0" Spacing="25">
            <Image Source="logo.png" HeightRequest="185" Aspect="AspectFit" SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label Text="The Card Vault" Style="{StaticResource Headline}" SemanticProperties.HeadingLevel="Level1" 
                   TextColor="{StaticResource PrimaryText}"/> <Label Text="Welcome to The Card Vault App" Style="{StaticResource SubHeadline}" SemanticProperties.HeadingLevel="Level2"
                   SemanticProperties.Description="Welcome to Card Vault App" 
                   TextColor="{StaticResource PrimaryText}"/> <HorizontalStackLayout HorizontalOptions="Center" Spacing="15" Margin="0,10,0,0">
                <Frame CornerRadius="12" Padding="5" BackgroundColor="{StaticResource CardBackground}" HasShadow="True">
                    <Image Source="card_back.png" WidthRequest="140" HeightRequest="200" Aspect="AspectFit" />
                </Frame>
                <Frame CornerRadius="12" Padding="5" BackgroundColor="{StaticResource CardBackground}" HasShadow="True">
                    <Image Source="card_front.png" WidthRequest="140" HeightRequest="200" Aspect="AspectFit" />
                </Frame>
            </HorizontalStackLayout>

            <Label Text="Dos et face d'une carte" FontSize="12" TextColor="{StaticResource SecondaryText}" HorizontalTextAlignment="Center" />
            
            <Button 
                x:Name="BtnShowGif"
                Text=" Voir l'animation magique"
                Clicked="OnShowGifClicked"
                BackgroundColor="{StaticResource AccentColor}" 
                TextColor="#1A2F24" 
                FontSize="16"
                FontAttributes="Bold"
                CornerRadius="10"
                Margin="0,10,0,0"
                HeightRequest="50" />
            
            <CarouselView x:Name="SuitCarousel" HeightRequest="180" PeekAreaInsets="40" Loop="True">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="15" Padding="20" BackgroundColor="{StaticResource CardBackground}" HasShadow="True" Margin="5">
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                                <Label Text="{Binding Symbol}" FontSize="60" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Name}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryText}" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Description}" FontSize="13" TextColor="{StaticResource SecondaryText}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <IndicatorView x:Name="SuitIndicator" 
                           IndicatorColor="{StaticResource SecondaryText}" 
                           SelectedIndicatorColor="{StaticResource AccentColor}"
                           IndicatorSize="8" HorizontalOptions="Center" Margin="0,0,0,30" />
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>