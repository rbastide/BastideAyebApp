<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BastideAyebApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:views="clr-namespace:BastideAyebApp.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BastideAyebApp"
    Title="The Card Vault"
    
    Shell.BackgroundColor="{StaticResource ShellBackground}"
    Shell.TitleColor="{StaticResource AccentColor}"
    
    Shell.ForegroundColor="{StaticResource AccentColor}"
    
    Shell.TabBarBackgroundColor="{StaticResource ShellBackground}"
    Shell.TabBarTitleColor="{StaticResource AccentColor}" 
    Shell.TabBarUnselectedColor="{StaticResource SecondaryText}"> 
    
    <TabBar>
        <Tab Title="Accueil" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        </Tab>

        <Tab Title="Tirage" Icon="cards.png">
            <ShellContent ContentTemplate="{DataTemplate local:DrawPage}" Route="DrawPage" />
        </Tab>

        <Tab Title="Ajouter" Icon="add.png">
            <ShellContent ContentTemplate="{DataTemplate views:AddCardPage}" Route="AddRulePage" />
        </Tab>

        <Tab Title="Jeux" Icon="bonus.png">
            <ShellContent ContentTemplate="{DataTemplate views:GamesPage}" Route="GamesPage" />
        </Tab>
    </TabBar>

</Shell>