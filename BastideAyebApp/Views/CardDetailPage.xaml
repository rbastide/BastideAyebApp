<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BastideAyebApp.Models"
             xmlns:viewmodels="clr-namespace:BastideAyebApp.ViewModels"
             x:Class="BastideAyebApp.Views.CardDetailPage"
             Title="Détail de la Carte"
             BackgroundColor="#1E1E1E">

    <VerticalStackLayout Padding="20" Spacing="25" HorizontalOptions="Center" VerticalOptions="Center">
        
        <Image Source="{Binding Card.Image}" HeightRequest="350" Aspect="AspectFit" />
        
        <Label Text="{Binding Card.Value}" FontSize="36" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
        
        <Label Text="{Binding Card.Suit}" FontSize="24" TextColor="#2E8B57" HorizontalOptions="Center" />
        
    </VerticalStackLayout>
</ContentPage>