<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BastideAyebApp.Views.CoinFlipPage"
             Title="Pile ou Face"
             BackgroundColor="#1E1E1E">

    <VerticalStackLayout VerticalOptions="Center" Spacing="20" Padding="30">

        <Label Text="🪙 Pile ou Face"
               FontSize="30" FontAttributes="Bold"
               TextColor="Gold" HorizontalTextAlignment="Center"/>

        <Label x:Name="CoinResultLabel"
               Text="Lancez la pièce !"
               FontSize="60"
               HorizontalTextAlignment="Center"
               TextColor="White"/>

        <Label x:Name="CoinTextLabel"
               Text=""
               FontSize="26" FontAttributes="Bold"
               HorizontalTextAlignment="Center"
               TextColor="Gold"/>

        <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
            <Label x:Name="PileScoreLabel" Text="Pile : 0"
                   FontSize="16" TextColor="LightGray"/>
            <Label Text=" | " FontSize="16" TextColor="Gray"/>
            <Label x:Name="FaceScoreLabel" Text="Face : 0"
                   FontSize="16" TextColor="LightGray"/>
        </HorizontalStackLayout>

        <Button Text="Lancer !"
                Clicked="OnCoinFlipClicked"
                BackgroundColor="Gold" TextColor="Black"
                FontAttributes="Bold" FontSize="20"
                CornerRadius="10" HeightRequest="55"
                HorizontalOptions="Fill"/>

    </VerticalStackLayout>
</ContentPage>