<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BastideAyebApp.Views.GamesPage"
             Title="Mini-Jeux"
             BackgroundColor="#1E1E1E">

    <VerticalStackLayout VerticalOptions="Center" Spacing="30" Padding="30">

        <Label Text="Mini-Jeux"
               FontSize="34" FontAttributes="Bold"
               HorizontalTextAlignment="Center" TextColor="White"/>

        <Label Text="Choisissez un jeu"
               FontSize="16"
               HorizontalTextAlignment="Center" TextColor="#A9A9A9"/>

        <Frame BackgroundColor="#4A148C" CornerRadius="15" Padding="20" BorderColor="Transparent">
            <VerticalStackLayout Spacing="10">
                <Label Text="🪙 Pile ou Face"
                       FontSize="24" FontAttributes="Bold" TextColor="Gold"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Lancez la pièce et tentez votre chance !"
                       FontSize="14" TextColor="White"
                       HorizontalTextAlignment="Center"/>
                <Button Text="Jouer"
                        Clicked="OnCoinFlipClicked"
                        BackgroundColor="Gold" TextColor="Black"
                        FontAttributes="Bold" CornerRadius="10"
                        HeightRequest="45"/>
            </VerticalStackLayout>
        </Frame>

        <Frame BackgroundColor="#1B5E20" CornerRadius="15" Padding="20" BorderColor="Transparent">
            <VerticalStackLayout Spacing="10">
                <Label Text="🔢 Nombre Mystère"
                       FontSize="24" FontAttributes="Bold" TextColor="White"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Devinez le nombre entre 1 et 100 !"
                       FontSize="14" TextColor="LightGray"
                       HorizontalTextAlignment="Center"/>
                <Button Text="Jouer"
                        Clicked="OnNumberGuessClicked"
                        BackgroundColor="#2E8B57" TextColor="White"
                        FontAttributes="Bold" CornerRadius="10"
                        HeightRequest="45"/>
            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>
</ContentPage>