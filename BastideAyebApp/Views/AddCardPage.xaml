<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:BastideAyebApp.ViewModels"
             x:Class="BastideAyebApp.Views.AddCardPage"
             Title="Ajouter une Carte">

    <ContentPage.BindingContext>
        <viewmodels:AddCardViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Créer une nouvelle carte" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />

            <Entry Placeholder="Titre de la carte" Text="{Binding Titre}" />
            <Entry Placeholder="Description (Ex: Carreau)" Text="{Binding Description}" />
            <Label Text="Image de la carte :" FontAttributes="Bold" Margin="0,10,0,0"/>
            
            <Image Source="{Binding Image}" 
                   HeightRequest="200" 
                   BackgroundColor="#F0F0F0" 
                   Aspect="AspectFit" />

            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Button Text="📷 Caméra" Command="{Binding TakePhotoCommand}" />
                <Button Text="🖼️ Galerie" Command="{Binding PickPhotoCommand}" />
            </HorizontalStackLayout>
            <Button Text="Ajouter à la liste" Command="{Binding AddCardCommand}" Margin="0,20,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>